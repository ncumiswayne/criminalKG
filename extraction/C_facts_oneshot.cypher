// === 檔C:第四層 Fact 節點(先執行下行約束,再整段執行)===
CREATE CONSTRAINT fact_fid IF NOT EXISTS FOR (n:Fact) REQUIRE n.fid IS UNIQUE;
UNWIND [{fid: 'F-2-3-6', subject: '處罰或保安處分之裁判確定後，未執行或執行未完畢，而法律有變更，不處罰其行為或不施以保安處分', predicate: '刑之減免', object: '免其刑或保安處分之執行', article: '2', para: 3, sentence: '處罰或保安處分之裁判確定後，未執行或執行未完畢，而法律有變更，不處罰其行為或不施以保安處分者，免其刑或保安處分之執行'}, {fid: 'F-3-1-8', subject: '在中華民國領域內犯罪', predicate: '定義', object: '在中華民國領域外之中華民國船艦或航空器內犯罪', article: '3', para: 1, sentence: '在中華民國領域外之中華民國船艦或航空器內犯罪者，以在中華民國領域內犯罪論'}, {fid: 'F-4-1-9', subject: '在中華民國領域內犯罪', predicate: '定義', object: '犯罪之行為或結果，有一在中華民國領域內', article: '4', para: 1, sentence: '犯罪之行為或結果，有一在中華民國領域內者，為在中華民國領域內犯罪'}, {fid: 'F-9-1-16', subject: '在外國已受刑之全部或一部執行', predicate: '刑之減免', object: '得免其刑之全部或一部之執行', article: '9', para: 1, sentence: '在外國已受刑之全部或一部執行者，得免其刑之全部或一部之執行'}, {fid: 'F-10-1-17', subject: '以上、以下、以內', predicate: '定義', object: '俱連本數或本刑計算', article: '10', para: 1, sentence: '稱以上、以下、以內者，俱連本數或本刑計算'}, {fid: 'F-10-2-18', subject: '公務員', predicate: '定義', object: '下列人員：一、依法令服務於國家、地方自治團體所屬機關而具有法定職務權限，以及其他依法令從事於公共事務，而具有法定職務權限者。二、受國家、地方自治團體所屬機關依法委託，從事與委託機關權限有關之公共事務者', article: '10', para: 2, sentence: '稱公務員者，謂下列人員：一、依法令服務於國家、地方自治團體所屬機關而具有法定職務權限，以及其他依法令從事於公共事務，而具有法定職務權限者。二、受國家、地方自治團體所屬機關依法委託，從事與委託機關權限有關之公共事務者'}, {fid: 'F-10-3-19', subject: '公文書', predicate: '定義', object: '公務員職務上製作之文書', article: '10', para: 3, sentence: '稱公文書者，謂公務員職務上製作之文書'}, {fid: 'F-10-4-20', subject: '重傷', predicate: '定義', object: '下列傷害：一、毀敗或嚴重減損一目或二目之視能。二、毀敗或嚴重減損一耳或二耳之聽能。三、毀敗或嚴重減損語能、味能或嗅能。四、毀敗或嚴重減損一肢以上之機能。五、毀敗或嚴重減損生殖之機能。六、其他於身體或健康，有重大不治或難治之傷害', article: '10', para: 4, sentence: '稱重傷者，謂下列傷害：一、毀敗或嚴重減損一目或二目之視能。二、毀敗或嚴重減損一耳或二耳之聽能。三、毀敗或嚴重減損語能、味能或嗅能。四、毀敗或嚴重減損一肢以上之機能。五、毀敗或嚴重減損生殖之機能。六、其他於身體或健康，有重大不治或難治之傷害'}, {fid: 'F-10-5-21', subject: '性交', predicate: '定義', object: '非基於正當目的所為之下列性侵入行為：一、以性器進入他人之性器、肛門或口腔，或使之接合之行為。二、以性器以外之其他身體部位或器物進入他人之性器、肛門，或使之接合之行為', article: '10', para: 5, sentence: '稱性交者，謂非基於正當目的所為之下列性侵入行為：一、以性器進入他人之性器、肛門或口腔，或使之接合之行為。二、以性器以外之其他身體部位或器物進入他人之性器、肛門，或使之接合之行為'}, {fid: 'F-10-6-22', subject: '電磁紀錄', predicate: '定義', object: '以電子、磁性、光學或其他相類之方式所製成，而供電腦處理之紀錄', article: '10', para: 6, sentence: '稱電磁紀錄者，謂以電子、磁性、光學或其他相類之方式所製成，而供電腦處理之紀錄'}, {fid: 'F-10-7-23', subject: '凌虐', predicate: '定義', object: '以強暴、脅迫或其他違反人道之方法，對他人施以凌辱虐待行為', article: '10', para: 7, sentence: '稱凌虐者，謂以強暴、脅迫或其他違反人道之方法，對他人施以凌辱虐待行為'}, {fid: 'F-10-8-24', subject: '性影像', predicate: '定義', object: '內容有下列各款之一之影像或電磁紀錄：一、第10條第5項第一款或第二款之行為。二、性器或客觀上足以引起性慾或羞恥之身體隱私部位。三、以身體或器物接觸前款部位，而客觀上足以引起性慾或羞恥之行為。四、其他與性相關而客觀上足以引起性慾或羞恥之行為', article: '10', para: 8, sentence: '稱性影像者，謂內容有下列各款之一之影像或電磁紀錄：一、第10條第5項第一款或第二款之行為。二、性器或客觀上足以引起性慾或羞恥之身體隱私部位。三、以身體或器物接觸前款部位，而客觀上足以引起性慾或羞恥之行為。四、其他與性相關而客觀上足以引起性慾或羞恥之行為'}, {fid: 'F-12-1-27', subject: '行為非出於故意或過失', predicate: '不罰', object: '成立', article: '12', para: 1, sentence: '行為非出於故意或過失者，不罰'}, {fid: 'F-13-1-29', subject: '故意', predicate: '定義', object: '行為人對於構成犯罪之事實，明知並有意使其發生', article: '13', para: 1, sentence: '行為人對於構成犯罪之事實，明知並有意使其發生者，為故意'}, {fid: 'F-13-2-30', subject: '故意', predicate: '定義', object: '行為人對於構成犯罪之事實，預見其發生而其發生並不違背其本意', article: '13', para: 2, sentence: '行為人對於構成犯罪之事實，預見其發生而其發生並不違背其本意者，以故意論'}, {fid: 'F-14-1-31', subject: '過失', predicate: '定義', object: '行為人雖非故意，但按其情節應注意，並能注意，而不注意', article: '14', para: 1, sentence: '行為人雖非故意，但按其情節應注意，並能注意，而不注意者，為過失'}, {fid: 'F-14-2-32', subject: '過失', predicate: '定義', object: '行為人對於構成犯罪之事實，雖預見其能發生而確信其不發生', article: '14', para: 2, sentence: '行為人對於構成犯罪之事實，雖預見其能發生而確信其不發生者，以過失論'}, {fid: 'F-16-1-35', subject: '除有正當理由而無法避免，外', predicate: '科刑限制', object: '不得因不知法律而免除刑事責任', article: '16', para: 1, sentence: '除有正當理由而無法避免者外，不得因不知法律而免除刑事責任'}, {fid: 'F-16-1-36', subject: '按其情節', predicate: '刑之減免', object: '得減輕其刑', article: '16', para: 1, sentence: '按其情節，得減輕其刑'}, {fid: 'F-18-1-38', subject: '未滿十四歲人之行為', predicate: '不罰', object: '成立', article: '18', para: 1, sentence: '未滿十四歲人之行為，不罰'}, {fid: 'F-18-2-39', subject: '十四歲以上未滿十八歲人之行為', predicate: '刑之減免', object: '得減輕其刑', article: '18', para: 2, sentence: '十四歲以上未滿十八歲人之行為，得減輕其刑'}, {fid: 'F-18-3-40', subject: '滿八十歲人之行為', predicate: '刑之減免', object: '得減輕其刑', article: '18', para: 3, sentence: '滿八十歲人之行為，得減輕其刑'}, {fid: 'F-19-1-41', subject: '行為時因精神障礙或其他心智缺陷，致不能辨識其行為違法或欠缺依其辨識而行為之能力', predicate: '不罰', object: '成立', article: '19', para: 1, sentence: '行為時因精神障礙或其他心智缺陷，致不能辨識其行為違法或欠缺依其辨識而行為之能力者，不罰'}, {fid: 'F-19-2-42', subject: '行為時因第19條第1項之原因，致其辨識行為違法或依其辨識而行為之能力，顯著減低', predicate: '刑之減免', object: '得減輕其刑', article: '19', para: 2, sentence: '行為時因第19條第1項之原因，致其辨識行為違法或依其辨識而行為之能力，顯著減低者，得減輕其刑'}, {fid: 'F-20-1-44', subject: '瘖啞人之行為', predicate: '刑之減免', object: '得減輕其刑', article: '20', para: 1, sentence: '瘖啞人之行為，得減輕其刑'}, {fid: 'F-21-1-45', subject: '依法令之行為', predicate: '不罰', object: '成立', article: '21', para: 1, sentence: '依法令之行為，不罰'}, {fid: 'F-21-2-46', subject: '依所屬上級公務員命令之職務上行為', predicate: '不罰', object: '成立', article: '21', para: 2, sentence: '依所屬上級公務員命令之職務上行為，不罰'}, {fid: 'F-21-2-47', subject: '明知命令違法', predicate: '不罰-例外', object: '不在此限', article: '21', para: 2, sentence: '但明知命令違法者，不在此限'}, {fid: 'F-22-1-48', subject: '業務上之正當行為', predicate: '不罰', object: '成立', article: '22', para: 1, sentence: '業務上之正當行為，不罰'}, {fid: 'F-23-1-49', subject: '對於現在不法之侵害，而出於防衛自己或他人權利之行為', predicate: '不罰', object: '成立', article: '23', para: 1, sentence: '對於現在不法之侵害，而出於防衛自己或他人權利之行為，不罰'}, {fid: 'F-23-1-50', subject: '防衛行為過當', predicate: '刑之減免', object: '得減輕或免除其刑', article: '23', para: 1, sentence: '防衛行為過當者，得減輕或免除其刑'}, {fid: 'F-24-1-51', subject: '因避免自己或他人生命、身體、自由、財產之緊急危難而出於不得已之行為', predicate: '不罰', object: '成立', article: '24', para: 1, sentence: '因避免自己或他人生命、身體、自由、財產之緊急危難而出於不得已之行為，不罰'}, {fid: 'F-24-1-52', subject: '避難行為過當', predicate: '刑之減免', object: '得減輕或免除其刑', article: '24', para: 1, sentence: '避難行為過當者，得減輕或免除其刑'}, {fid: 'F-25-1-54', subject: '未遂犯', predicate: '定義', object: '已著手於犯罪行為之實行而不遂', article: '25', para: 1, sentence: '已著手於犯罪行為之實行而不遂者，為未遂犯'}, {fid: 'F-25-2-55', subject: '未遂犯', predicate: '刑之減免', object: '得按既遂犯之刑減輕之', article: '25', para: 2, sentence: '未遂犯之處罰，以有特別規定者為限，並得按既遂犯之刑減輕之'}, {fid: 'F-26-1-56', subject: '行為不能發生犯罪之結果，又無危險', predicate: '不罰', object: '成立', article: '26', para: 1, sentence: '行為不能發生犯罪之結果，又無危險者，不罰'}, {fid: 'F-27-1-57', subject: '已著手於犯罪行為之實行，而因己意中止或防止其結果之發生', predicate: '刑之減免', object: '減輕或免除其刑', article: '27', para: 1, sentence: '已著手於犯罪行為之實行，而因己意中止或防止其結果之發生者，減輕或免除其刑'}, {fid: 'F-27-1-58', subject: '結果之不發生，非防止行為所致，而行為人已盡力為防止行為', predicate: '刑之減免', object: '減輕或免除其刑', article: '27', para: 1, sentence: '結果之不發生，非防止行為所致，而行為人已盡力為防止行為者，亦同'}, {fid: 'F-28-1-60', subject: '正犯', predicate: '定義', object: '二人以上共同實行犯罪之行為', article: '28', para: 1, sentence: '二人以上共同實行犯罪之行為者，皆為正犯'}, {fid: 'F-29-1-61', subject: '教唆犯', predicate: '定義', object: '教唆他人使之實行犯罪行為', article: '29', para: 1, sentence: '教唆他人使之實行犯罪行為者，為教唆犯'}, {fid: 'F-29-2-62', subject: '教唆犯', predicate: '處罰依據', object: '依其所教唆之罪處罰之', article: '29', para: 2, sentence: '教唆犯之處罰，依其所教唆之罪處罰之'}, {fid: 'F-30-1-63', subject: '幫助犯', predicate: '定義', object: '幫助他人實行犯罪行為', article: '30', para: 1, sentence: '幫助他人實行犯罪行為者，為幫助犯'}, {fid: 'F-30-1-64', subject: '雖他人不知幫助之情', predicate: '定義', object: '幫助他人實行犯罪行為', article: '30', para: 1, sentence: '雖他人不知幫助之情者，亦同'}, {fid: 'F-30-2-65', subject: '幫助犯', predicate: '刑之減免', object: '得按正犯之刑減輕之', article: '30', para: 2, sentence: '幫助犯之處罰，得按正犯之刑減輕之'}, {fid: 'F-31-2-68', subject: '因身分或其他特定關係致刑有重輕或免除，其無特定關係之人', predicate: '法定刑', object: '科以通常之刑', article: '31', para: 2, sentence: '因身分或其他特定關係致刑有重輕或免除者，其無特定關係之人，科以通常之刑', penalty_raw: '科以通常之刑'}, {fid: 'F-32-1-69', subject: '刑', predicate: '定義', object: '主刑及從刑', article: '32', para: 1, sentence: '刑分為主刑及從刑'}, {fid: 'F-33-1-70', subject: '主刑', predicate: '定義', object: '一、死刑。二、無期徒刑。三、有期徒刑：二月以上十五年以下。但遇有加減時，得減至二月未滿，或加至二十年。四、拘役：一日以上，六十日未滿。但遇有加重時，得加至一百二十日。五、罰金：新臺幣一千元以上，以百元計算之', article: '33', para: 1, sentence: '主刑之種類如下：一、死刑。二、無期徒刑。三、有期徒刑：二月以上十五年以下。但遇有加減時，得減至二月未滿，或加至二十年。四、拘役：一日以上，六十日未滿。但遇有加重時，得加至一百二十日。五、罰金：新臺幣一千元以上，以百元計算之'}, {fid: 'F-36-1-75', subject: '從刑', predicate: '定義', object: '褫奪公權', article: '36', para: 1, sentence: '從刑為褫奪公權'}, {fid: 'F-38-2-88', subject: '供犯罪所用、犯罪預備之物或犯罪所生之物，屬於犯罪行為人', predicate: '沒收', object: '得沒收之', article: '38', para: 2, sentence: '供犯罪所用、犯罪預備之物或犯罪所生之物，屬於犯罪行為人者，得沒收之'}, {fid: 'F-38-3-90', subject: '第38條第2項之物屬於犯罪行為人以外之自然人、法人或非法人團體，而無正當理由提供或取得', predicate: '沒收', object: '得沒收之', article: '38', para: 3, sentence: '第38條第2項之物屬於犯罪行為人以外之自然人、法人或非法人團體，而無正當理由提供或取得者，得沒收之'}, {fid: 'F-38-1-1-92', subject: '犯罪所得，屬於犯罪行為人', predicate: '沒收', object: '沒收之', article: '38-1', para: 1, sentence: '犯罪所得，屬於犯罪行為人者，沒收之'}, {fid: 'F-40-2-4-110', subject: '沒收之宣告，自裁判確定之日起，逾十年未開始或繼續執行', predicate: '科刑限制', object: '不得執行', article: '40-2', para: 4, sentence: '沒收之宣告，自裁判確定之日起，逾十年未開始或繼續執行者，不得執行'}, {fid: 'F-42-8-137', subject: '易服勞役期內納罰金，以所納之數', predicate: '處罰依據', object: '依裁判所定之標準折算，扣除勞役之日期', article: '42', para: 8, sentence: '易服勞役期內納罰金者，以所納之數，依裁判所定之標準折算，扣除勞役之日期'}, {fid: 'F-42-1-5-142', subject: '社會勞動履行期間內繳納罰金，以所納之數', predicate: '處罰依據', object: '依裁判所定罰金易服勞役之標準折算，扣除社會勞動之日數', article: '42-1', para: 5, sentence: '社會勞動履行期間內繳納罰金者，以所納之數，依裁判所定罰金易服勞役之標準折算，扣除社會勞動之日數'}, {fid: 'F-42-1-6-143', subject: '依第42-1條第3項執行勞役，於勞役期內納罰金，以所納之數', predicate: '處罰依據', object: '依裁判所定罰金易服勞役之標準折算，扣除社會勞動與勞役之日數', article: '42-1', para: 6, sentence: '依第42-1條第3項執行勞役，於勞役期內納罰金者，以所納之數，依裁判所定罰金易服勞役之標準折算，扣除社會勞動與勞役之日數'}, {fid: 'F-47-1-146', subject: '受徒刑之執行完畢，或一部之執行而赦免後，五年以內故意再犯有期徒刑以上之罪，為累犯', predicate: '刑之加重', object: '加重本刑至二分之一', article: '47', para: 1, sentence: '受徒刑之執行完畢，或一部之執行而赦免後，五年以內故意再犯有期徒刑以上之罪者，為累犯，加重本刑至二分之一'}, {fid: 'F-47-2-147', subject: '累犯', predicate: '定義', object: '第98條第2項關於因強制工作而免其刑之執行者，於受強制工作處分之執行完畢或一部之執行而免除後，五年以內故意再犯有期徒刑以上之罪', article: '47', para: 2, sentence: '第98條第2項關於因強制工作而免其刑之執行者，於受強制工作處分之執行完畢或一部之執行而免除後，五年以內故意再犯有期徒刑以上之罪者，以累犯論'}, {fid: 'F-48-1-148', subject: '裁判確定後，發覺為累犯', predicate: '處罰依據', object: '依第47條之規定更定其刑', article: '48', para: 1, sentence: '裁判確定後，發覺為累犯者，依第47條之規定更定其刑'}, {fid: 'F-48-1-149', subject: '刑之執行完畢或赦免後發覺', predicate: '處罰依據-例外', object: '不在此限', article: '48', para: 1, sentence: '但刑之執行完畢或赦免後發覺者，不在此限'}, {fid: 'F-50-1-151', subject: '裁判確定前犯數罪', predicate: '處罰依據', object: '併合處罰之。但有下列情形之一者，不在此限：一、得易科罰金之罪與不得易科罰金之罪。二、得易科罰金之罪與不得易服社會勞動之罪。三、得易服社會勞動之罪與不得易科罰金之罪。四、得易服社會勞動之罪與不得易服社會勞動之罪', article: '50', para: 1, sentence: '裁判確定前犯數罪者，併合處罰之。但有下列情形之一者，不在此限：一、得易科罰金之罪與不得易科罰金之罪。二、得易科罰金之罪與不得易服社會勞動之罪。三、得易服社會勞動之罪與不得易科罰金之罪。四、得易服社會勞動之罪與不得易服社會勞動之罪'}, {fid: 'F-50-2-152', subject: '第50條第1項但書情形，受刑人請求檢察官聲請定應執行刑', predicate: '處罰依據', object: '依第51條規定定之', article: '50', para: 2, sentence: '第50條第1項但書情形，受刑人請求檢察官聲請定應執行刑者，依第51條規定定之'}, {fid: 'F-53-1-155', subject: '數罪併罰，有二裁判以上', predicate: '處罰依據', object: '依第51條之規定，定其應執行之刑', article: '53', para: 1, sentence: '數罪併罰，有二裁判以上者，依第51條之規定，定其應執行之刑'}, {fid: 'F-54-1-156', subject: '數罪併罰，已經處斷，如各罪中有受赦免者，餘罪仍依第51條之規定，定其應執行之刑，僅餘一罪', predicate: '處罰依據', object: '依其宣告之刑執行', article: '54', para: 1, sentence: '數罪併罰，已經處斷，如各罪中有受赦免者，餘罪仍依第51條之規定，定其應執行之刑，僅餘一罪者，依其宣告之刑執行'}, {fid: 'F-55-1-157', subject: '一行為而觸犯數罪名', predicate: '處罰依據', object: '從一重處斷', article: '55', para: 1, sentence: '一行為而觸犯數罪名者，從一重處斷'}, {fid: 'F-59-1-162', subject: '犯罪之情狀顯可憫恕，認科以最低度刑仍嫌過重', predicate: '刑之減免', object: '得酌量減輕其刑', article: '59', para: 1, sentence: '犯罪之情狀顯可憫恕，認科以最低度刑仍嫌過重者，得酌量減輕其刑'}, {fid: 'F-60-1-163', subject: '依法律加重或減輕', predicate: '刑之減免', object: '仍得依第59條之規定酌量減輕其刑', article: '60', para: 1, sentence: '依法律加重或減輕者，仍得依第59條之規定酌量減輕其刑'}, {fid: 'F-61-1-164', subject: '犯下列各罪之一，情節輕微，顯可憫恕，認為依第59條規定減輕其刑仍嫌過重', predicate: '刑之減免', object: '得免除其刑：一、最重本刑為三年以下有期徒刑、拘役或專科罰金之罪。但第132條第1項、第143條、第145條、第186條及對於直系血親尊親屬犯第271條第3項之罪，不在此限。二、第320條、第321條之竊盜罪。三、第335條、第336條第2項之侵占罪。四、第339條、第341條之詐欺罪。五、第342條之背信罪。六、第346條之恐嚇罪。七、第349條第2項之贓物罪', article: '61', para: 1, sentence: '犯下列各罪之一，情節輕微，顯可憫恕，認為依第59條規定減輕其刑仍嫌過重者，得免除其刑：一、最重本刑為三年以下有期徒刑、拘役或專科罰金之罪。但第132條第1項、第143條、第145條、第186條及對於直系血親尊親屬犯第271條第3項之罪，不在此限。二、第320條、第321條之竊盜罪。三、第335條、第336條第2項之侵占罪。四、第339條、第341條之詐欺罪。五、第342條之背信罪。六、第346條之恐嚇罪。七、第349條第2項之贓物罪'}, {fid: 'F-62-1-165', subject: '對於未發覺之罪自首而受裁判', predicate: '刑之減免', object: '得減輕其刑', article: '62', para: 1, sentence: '對於未發覺之罪自首而受裁判者，得減輕其刑'}, {fid: 'F-63-1-167', subject: '未滿十八歲人或滿八十歲人犯罪', predicate: '科刑限制', object: '不得處死刑或無期徒刑，本刑為死刑或無期徒刑者，減輕其刑', article: '63', para: 1, sentence: '未滿十八歲人或滿八十歲人犯罪者，不得處死刑或無期徒刑，本刑為死刑或無期徒刑者，減輕其刑'}, {fid: 'F-66-1-172', subject: '有期徒刑、拘役、罰金減輕', predicate: '刑之減免', object: '減輕其刑至二分之一', article: '66', para: 1, sentence: '有期徒刑、拘役、罰金減輕者，減輕其刑至二分之一'}, {fid: 'F-86-1-233', subject: '因未滿十四歲而不罰', predicate: '保安處分', object: '得令入感化教育處所，施以感化教育', article: '86', para: 1, sentence: '因未滿十四歲而不罰者，得令入感化教育處所，施以感化教育'}, {fid: 'F-86-2-234', subject: '因未滿十八歲而減輕其刑，得於刑之執行完畢或赦免後', predicate: '保安處分', object: '令入感化教育處所，施以感化教育', article: '86', para: 2, sentence: '因未滿十八歲而減輕其刑者，得於刑之執行完畢或赦免後，令入感化教育處所，施以感化教育'}, {fid: 'F-87-1-238', subject: '因第19條第1項之原因而不罰，其情狀足認有再犯或有危害公共安全之虞時', predicate: '保安處分', object: '令入相當處所或以適當方式，施以監護', article: '87', para: 1, sentence: '因第19條第1項之原因而不罰者，其情狀足認有再犯或有危害公共安全之虞時，令入相當處所或以適當方式，施以監護'}, {fid: 'F-88-1-245', subject: '施用毒品成癮', predicate: '保安處分', object: '於刑之執行前令入相當處所，施以禁戒', article: '88', para: 1, sentence: '施用毒品成癮者，於刑之執行前令入相當處所，施以禁戒'}, {fid: 'F-89-1-248', subject: '因酗酒而犯罪，足認其已酗酒成癮並有再犯之虞，於刑之執行前', predicate: '保安處分', object: '令入相當處所，施以禁戒', article: '89', para: 1, sentence: '因酗酒而犯罪，足認其已酗酒成癮並有再犯之虞者，於刑之執行前，令入相當處所，施以禁戒'}, {fid: 'F-90-1-251', subject: '有犯罪之習慣或因遊蕩或懶惰成習而犯罪，於刑之執行前', predicate: '保安處分', object: '令入勞動場所，強制工作', article: '90', para: 1, sentence: '有犯罪之習慣或因遊蕩或懶惰成習而犯罪者，於刑之執行前，令入勞動場所，強制工作'}, {fid: 'F-91-1-1-255', subject: '犯第221條至第227條、第228條、第229條、第230條、第234條、第332條第2項第二款、第334條第2項第二款、第348條第2項第一款及其特別法之罪，而有下列情形之一', predicate: '保安處分', object: '得令入相當處所，施以強制治療：一、徒刑執行期滿前，於接受輔導或治療後，經鑑定、評估，認有再犯之危險者。二、依其他法律規定，於接受身心治療、輔導或教育後，經鑑定、評估，認有再犯之危險者', article: '91-1', para: 1, sentence: '犯第221條至第227條、第228條、第229條、第230條、第234條、第332條第2項第二款、第334條第2項第二款、第348條第2項第一款及其特別法之罪，而有下列情形之一者，得令入相當處所，施以強制治療：一、徒刑執行期滿前，於接受輔導或治療後，經鑑定、評估，認有再犯之危險者。二、依其他法律規定，於接受身心治療、輔導或教育後，經鑑定、評估，認有再犯之危險者'}, {fid: 'F-93-1-265', subject: '受緩刑之宣告，除有下列情形之一', predicate: '保安處分', object: '應於緩刑期間付保護管束外，得於緩刑期間付保護管束：一、犯第91-1條所列之罪者。二、執行第74條第2項第五款至第八款所定之事項者', article: '93', para: 1, sentence: '受緩刑之宣告者，除有下列情形之一，應於緩刑期間付保護管束外，得於緩刑期間付保護管束：一、犯第91-1條所列之罪者。二、執行第74條第2項第五款至第八款所定之事項者'}, {fid: 'F-95-1-267', subject: '外國人受有期徒刑以上刑之宣告', predicate: '保安處分', object: '得於刑之執行完畢或赦免後，驅逐出境', article: '95', para: 1, sentence: '外國人受有期徒刑以上刑之宣告者，得於刑之執行完畢或赦免後，驅逐出境'}, {fid: 'F-99-1-275', subject: '保安處分自應執行之日起逾三年未開始或繼續執行，非經法院認為原宣告保安處分之原因仍繼續存在時', predicate: '科刑限制', object: '不得許可執行', article: '99', para: 1, sentence: '保安處分自應執行之日起逾三年未開始或繼續執行者，非經法院認為原宣告保安處分之原因仍繼續存在時，不得許可執行'}, {fid: 'F-99-1-276', subject: '逾七年未開始或繼續執行', predicate: '科刑限制', object: '不得執行', article: '99', para: 1, sentence: '逾七年未開始或繼續執行者，不得執行'}, {fid: 'F-271-1-277', subject: '殺人', predicate: '法定刑', object: '處死刑、無期徒刑或十年以上有期徒刑', article: '271', para: 1, sentence: '殺人者，處死刑、無期徒刑或十年以上有期徒刑', penalty_raw: '處死刑、無期徒刑或十年以上有期徒刑', penalty_min: '10年', penalty_types: '死刑、無期徒刑、有期徒刑', penalty_min_months: 120}, {fid: 'F-271-2-278', subject: '第271條第1項之罪', predicate: '未遂處罰', object: '成立', article: '271', para: 2, sentence: '第271條第1項之未遂犯罰之'}, {fid: 'F-271-3-279', subject: '預備犯第271條第1項之罪', predicate: '法定刑', object: '處二年以下有期徒刑', article: '271', para: 3, sentence: '預備犯第271條第1項之罪者，處二年以下有期徒刑', penalty_raw: '處二年以下有期徒刑', penalty_max: '2年', penalty_types: '有期徒刑', penalty_max_months: 24}, {fid: 'F-272-1-280', subject: '對於直系血親尊親屬，犯第271條之罪', predicate: '刑之加重', object: '加重其刑至二分之一', article: '272', para: 1, sentence: '對於直系血親尊親屬，犯第271條之罪者，加重其刑至二分之一'}, {fid: 'F-272-1-1-281', subject: '對於未滿七歲之人犯第271條之罪', predicate: '刑之加重', object: '加重其刑二分之一', article: '272-1', para: 1, sentence: '對於未滿七歲之人犯第271條之罪者，加重其刑二分之一'}, {fid: 'F-272-1-2-282', subject: '對於未滿七歲之人，以凌虐方式犯第271條第1項之罪', predicate: '法定刑', object: '處死刑或無期徒刑', article: '272-1', para: 2, sentence: '對於未滿七歲之人，以凌虐方式犯第271條第1項之罪者，處死刑或無期徒刑', penalty_raw: '處死刑或無期徒刑', penalty_types: '死刑、無期徒刑'}, {fid: 'F-272-1-3-283', subject: '第272-1條第2項之罪', predicate: '未遂處罰', object: '成立', article: '272-1', para: 3, sentence: '第272-1條第2項之未遂犯罰之'}, {fid: 'F-272-1-4-284', subject: '預備犯第272-1條第2項之罪', predicate: '法定刑', object: '處五年以下有期徒刑', article: '272-1', para: 4, sentence: '預備犯第272-1條第2項之罪者，處五年以下有期徒刑', penalty_raw: '處五年以下有期徒刑', penalty_max: '5年', penalty_types: '有期徒刑', penalty_max_months: 60}, {fid: 'F-273-1-285', subject: '當場激於義憤而殺人', predicate: '法定刑', object: '處七年以下有期徒刑', article: '273', para: 1, sentence: '當場激於義憤而殺人者，處七年以下有期徒刑', penalty_raw: '處七年以下有期徒刑', penalty_max: '7年', penalty_types: '有期徒刑', penalty_max_months: 84}, {fid: 'F-273-2-286', subject: '第273條第1項之罪', predicate: '未遂處罰', object: '成立', article: '273', para: 2, sentence: '第273條第1項之未遂犯罰之'}, {fid: 'F-274-1-287', subject: '母因不得已之事由，於生產時或甫生產後，殺其子女', predicate: '法定刑', object: '處六月以上五年以下有期徒刑', article: '274', para: 1, sentence: '母因不得已之事由，於生產時或甫生產後，殺其子女者，處六月以上五年以下有期徒刑', penalty_raw: '處六月以上五年以下有期徒刑', penalty_min: '6月', penalty_max: '5年', penalty_types: '有期徒刑', penalty_min_months: 6, penalty_max_months: 60}, {fid: 'F-274-2-288', subject: '第274條第1項之罪', predicate: '未遂處罰', object: '成立', article: '274', para: 2, sentence: '第274條第1項之未遂犯罰之'}, {fid: 'F-275-1-289', subject: '受他人囑託或得其承諾而殺之', predicate: '法定刑', object: '處一年以上七年以下有期徒刑', article: '275', para: 1, sentence: '受他人囑託或得其承諾而殺之者，處一年以上七年以下有期徒刑', penalty_raw: '處一年以上七年以下有期徒刑', penalty_min: '1年', penalty_max: '7年', penalty_types: '有期徒刑', penalty_min_months: 12, penalty_max_months: 84}, {fid: 'F-275-2-290', subject: '教唆或幫助他人使之自殺', predicate: '法定刑', object: '處五年以下有期徒刑', article: '275', para: 2, sentence: '教唆或幫助他人使之自殺者，處五年以下有期徒刑', penalty_raw: '處五年以下有期徒刑', penalty_max: '5年', penalty_types: '有期徒刑', penalty_max_months: 60}, {fid: 'F-275-3-291', subject: '第275條第1項之罪', predicate: '未遂處罰', object: '成立', article: '275', para: 3, sentence: '第275條第1項、第275條第2項之未遂犯罰之'}, {fid: 'F-275-3-292', subject: '第275條第2項之罪', predicate: '未遂處罰', object: '成立', article: '275', para: 3, sentence: '第275條第1項、第275條第2項之未遂犯罰之'}, {fid: 'F-275-4-293', subject: '謀為同死而犯第275條第1項、第275條第2項、第275條第3項之罪', predicate: '刑之減免', object: '得免除其刑', article: '275', para: 4, sentence: '謀為同死而犯第275條第1項、第275條第2項、第275條第3項之罪者，得免除其刑'}, {fid: 'F-276-1-294', subject: '因過失致人於死', predicate: '法定刑', object: '處五年以下有期徒刑、拘役或五十萬元以下罰金', article: '276', para: 1, sentence: '因