 {trigger: '未遂犯罰之', basis: '未遂犯罰之(punishes_attempt 屬性播種)', para: 0, applies: true, review: 'approved'}}, {acode: '刑法-335', cid: 'C-未遂', props: {trigger: '未遂犯罰之', basis: '未遂犯罰之(punishes_attempt 屬性播種)', para: 0, applies: true, review: 'approved'}}, {acode: '刑法-336', cid: 'C-未遂', props: {trigger: '未遂犯罰之', basis: '未遂犯罰之(punishes_attempt 屬性播種)', para: 0, applies: true, review: 'approved'}}, {acode: '刑法-339', cid: 'C-未遂', props: {trigger: '未遂犯罰之', basis: '未遂犯罰之(punishes_attempt 屬性播種)', para: 0, applies: true, review: 'approved'}}, {acode: '刑法-339-1', cid: 'C-未遂', props: {trigger: '未遂犯罰之', basis: '未遂犯罰之(punishes_attempt 屬性播種)', para: 0, applies: true, review: 'approved'}}, {acode: '刑法-339-2', cid: 'C-未遂', props: {trigger: '未遂犯罰之', basis: '未遂犯罰之(punishes_attempt 屬性播種)', para: 0, applies: true, review: 'approved'}}, {acode: '刑法-339-3', cid: 'C-未遂', props: {trigger: '未遂犯罰之', basis: '未遂犯罰之(punishes_attempt 屬性播種)', para: 0, applies: true, review: 'approved'}}, {acode: '刑法-339-4', cid: 'C-未遂', props: {trigger: '未遂犯罰之', basis: '未遂犯罰之(punishes_attempt 屬性播種)', para: 0, applies: true, review: 'approved'}}, {acode: '刑法-341', cid: 'C-未遂', props: {trigger: '未遂犯罰之', basis: '未遂犯罰之(punishes_attempt 屬性播種)', para: 0, applies: true, review: 'approved'}}, {acode: '刑法-342', cid: 'C-未遂', props: {trigger: '未遂犯罰之', basis: '未遂犯罰之(punishes_attempt 屬性播種)', para: 0, applies: true, review: 'approved'}}, {acode: '刑法-344-1', cid: 'C-未遂', props: {trigger: '未遂犯罰之', basis: '未遂犯罰之(punishes_attempt 屬性播種)', para: 0, applies: true, review: 'approved'}}, {acode: '刑法-346', cid: 'C-未遂', props: {trigger: '未遂犯罰之', basis: '未遂犯罰之(punishes_attempt 屬性播種)', para: 0, applies: true, review: 'approved'}}, {acode: '刑法-347', cid: 'C-未遂', props: {trigger: '未遂犯罰之', basis: '未遂犯罰之(punishes_attempt 屬性播種)', para: 0, applies: true, review: 'approved'}}, {acode: '刑法-353', cid: 'C-未遂', props: {trigger: '未遂犯罰之', basis: '未遂犯罰之(punishes_attempt 屬性播種)', para: 0, applies: true, review: 'approved'}}, {acode: '刑法-31', cid: 'C-教唆犯', props: {trigger: '教唆', basis: '因身分或其他特定關係成立之罪，其共同實行、教唆或幫助者，雖無特定關係，仍以正犯或共犯論。但得減輕其刑。', para: 1, applies: true, review: 'pending'}}, {acode: '刑法-275', cid: 'C-教唆犯', props: {trigger: '教唆', basis: '教唆或幫助他人使之自殺者，處五年以下有期徒刑。', para: 2, applies: false, review: 'rejected', reason: '教唆自殺為獨立構成要件:§29 教唆犯有從屬性,被教唆行為須為犯罪;自殺非犯罪,無法經 §29 成罪,立法者特別入罪(canonical 反例)'}}, {acode: '刑法-282', cid: 'C-教唆犯', props: {trigger: '教唆', basis: '教唆或幫助他人使之自傷，因而致死者，處五年以下有期徒刑；致重傷者，處二年以下有期徒刑。', para: 2, applies: false, review: 'rejected', reason: '教唆自傷為獨立構成要件:自傷非犯罪,同 §275 之理,不適用 §29'}}, {acode: '刑法-31', cid: 'C-幫助犯', props: {trigger: '幫助', basis: '因身分或其他特定關係成立之罪，其共同實行、教唆或幫助者，雖無特定關係，仍以正犯或共犯論。但得減輕其刑。', para: 1, applies: true, review: 'pending'}}, {acode: '刑法-107', cid: 'C-幫助犯', props: {trigger: '幫助', basis: '五、為敵國之間諜，或幫助敵國之間諜者。', para: 6, applies: false, review: 'rejected', reason: '「幫助敵國之間諜」為幫助行為之正犯化(獨立加重構成要件),依本款以正犯論處,不依 §30 幫助犯得減輕'}}, {acode: '刑法-275', cid: 'C-幫助犯', props: {trigger: '幫助', basis: '教唆或幫助他人使之自殺者，處五年以下有期徒刑。', para: 2, applies: false, review: 'rejected', reason: '幫助自殺為獨立構成要件:自殺非犯罪,§30 從屬性不適用,立法者特別入罪'}}, {acode: '刑法-282', cid: 'C-幫助犯', props: {trigger: '幫助', basis: '教唆或幫助他人使之自傷，因而致死者，處五年以下有期徒刑；致重傷者，處二年以下有期徒刑。', para: 2, applies: false, review: 'rejected', reason: '幫助自傷為獨立構成要件:自傷非犯罪,同 §275 之理,不適用 §30'}}, {acode: '刑法-48', cid: 'C-累犯', props: {trigger: '累犯', basis: '裁判確定後，發覺為累犯者，依前條之規定更定其刑。但刑之執行完畢或赦免後發覺者，不在此限。', para: 1, applies: true, review: 'pending'}}, {acode: '刑法-49', cid: 'C-累犯', props: {trigger: '累犯', basis: '累犯之規定，於前所犯罪在外國法院受裁判者，不適用之。', para: 1, applies: true, review: 'pending'}}, {acode: '刑法-77', cid: 'C-累犯', props: {trigger: '累犯', basis: '受徒刑之執行而有悛悔實據者，無期徒刑逾二十五年，有期徒刑逾二分之一、累犯逾三分之二，由監獄報請法務部，得許假釋出獄。', para: 1, applies: true, review: 'pending'}}, {acode: '刑法-102', cid: 'C-自首', props: {trigger: '自首', basis: '犯第一百條第二項或第一百零一條第二項之罪而自首者，減輕或免除其刑。', para: 1, applies: true, review: 'pending'}}, {acode: '刑法-122', cid: 'C-自首', props: {trigger: '自首', basis: '對於公務員或仲裁人關於違背職務之行為，行求、期約或交付賄賂或其他不正利益者，處三年以下有期徒刑，得併科三十萬元以下罰金。但自首者減輕或免除其刑。在偵查或審判中自', para: 3, applies: true, review: 'pending'}}, {acode: '刑法-154', cid: 'C-自首', props: {trigger: '自首', basis: '犯前項之罪而自首者，減輕或免除其刑。', para: 2, applies: true, review: 'pending'}}] AS u MATCH (a:Article {code: u.acode}), (c:Concept {cid: u.cid}) MERGE (a)-[r:USES]->(c) SET r += u.props
WITH count(*) AS _ MATCH (c:Concept) RETURN count(c) AS Concept數;
